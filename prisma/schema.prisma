  description String?
  type        String   // academic, cultural, sports, workshop, seminar
  startDate   DateTime
  endDate     DateTime?
  venue       String?
  organizer   String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("events")
}

model Holiday {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  date        DateTime
  type        String   // national, state, institutional
  description String?
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("holidays")
}
